---
import { Icon } from '@astrojs/starlight/components';
---

<vessl-theme-toggle>
  <button aria-label="Toggle theme" title="Toggle theme">
    <Icon name="sun" class="sun-icon" />
    <Icon name="moon" class="moon-icon" />
  </button>
</vessl-theme-toggle>

<style>
  button {
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--sl-color-text-accent);
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }
  button:hover {
    color: var(--sl-color-white);
    background: rgba(255, 255, 255, 0.05);
  }
  :global([data-theme='light']) .sun-icon {
    display: none;
  }
  :global([data-theme='dark']) .moon-icon {
    display: none;
  }
  :global(:not([data-theme='light']):not([data-theme='dark'])) {
    @media (prefers-color-scheme: light) {
      .sun-icon { display: none; }
    }
    @media (prefers-color-scheme: dark) {
      .moon-icon { display: none; }
    }
  }
</style>

<script>
  class VesslThemeToggle extends HTMLElement {
    constructor() {
      super();
      const button = this.querySelector('button');
      button?.addEventListener('click', () => {
        let currentTheme = document.documentElement.dataset.theme;
        
        if (!currentTheme || currentTheme === 'auto') {
            currentTheme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        }

        const newTheme = currentTheme === 'light' ? 'dark' : 'light';
        document.documentElement.dataset.theme = newTheme;
        
        if (typeof localStorage !== 'undefined') {
          localStorage.setItem('starlight-theme', newTheme);
        }
      });
    }
  }
  customElements.define('vessl-theme-toggle', VesslThemeToggle);
</script>
