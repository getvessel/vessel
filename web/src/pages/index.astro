---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    icon: `<path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/>`,
    title: 'Any Language',
    desc: 'Deploy any app regardless of language or framework — static sites, APIs, workers, and everything in between.',
  },
  {
    icon: `<rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>`,
    title: 'Any Server',
    desc: 'Deploy to your own VPS, bare metal, Raspberry Pi, EC2, Hetzner, or DigitalOcean. All you need is an SSH connection.',
  },
  {
    icon: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>`,
    title: 'Push to Deploy',
    desc: 'Connect GitHub, GitLab, Gitea, or any self-hosted Git. Every push triggers a clean build and deploy.',
  },
  {
    icon: `<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>`,
    title: 'Automatic SSL',
    desc: "Let's Encrypt certificates provisioned and renewed automatically for every custom domain you connect.",
  },
  {
    icon: `<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>`,
    title: 'Databases',
    desc: 'Postgres, MySQL, Redis, MongoDB, ClickHouse — one click to run on your server, fully managed.',
  },
  {
    icon: `<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`,
    title: 'Real-time Terminal',
    desc: 'SSH into any running container directly from your browser. No client or local keys required.',
  },
  {
    icon: `<path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/>`,
    title: 'Usage Metering',
    desc: 'Track container hours, deployments, and bandwidth. Get notified before you hit plan limits.',
  },
  {
    icon: `<circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><line x1="6" y1="9" x2="6" y2="21"/>`,
    title: 'PR Previews',
    desc: 'Every pull request gets its own live preview environment. Merge with confidence.',
  },
  {
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
    title: 'Encrypted Secrets',
    desc: 'Environment variables encrypted at rest. Never stored in plain text.',
  },
  {
    icon: `<path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>`,
    title: 'Fleet Management',
    desc: 'Control hundreds of servers from a single Vessl Cloud dashboard. Deploy everywhere at once.',
  },
  {
    icon: `<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>`,
    title: 'Webhooks & API',
    desc: 'Integrate into your CI/CD pipeline or trigger deploys programmatically via the REST API.',
  },
  {
    icon: `<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>`,
    title: 'Notifications',
    desc: 'Get notified via email, webhook, or Discord when deployments succeed, fail, or exceed limits.',
  },
];

const steps = [
  {
    n: '01',
    title: 'Install the agent',
    desc: 'Run a single curl command on any Linux server. The <30MB binary installs and connects in seconds.',
  },
  {
    n: '02',
    title: 'Connect to Vessl Cloud',
    desc: 'Register your server with a Cloud token. It appears instantly in your fleet dashboard.',
  },
  {
    n: '03',
    title: 'Push and deploy',
    desc: 'Push to your Git repo. Vessl builds, deploys, and routes traffic automatically. Done.',
  },
];
---

<Layout title="Vessl — Self-hosting with superpowers" description="Deploy apps, databases & services to your own server. Open-source alternative to Heroku, Vercel, and Railway.">

  <!-- Hero -->
  <section class="text-center pt-16 md:pt-28 pb-4 px-4">
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-[var(--color-foreground)] mb-4">
      Self-hosting with superpowers<span class="text-[var(--color-primary)]">.</span>
    </h1>
    <h2 class="text-base text-[var(--color-muted-foreground)] max-w-3xl mx-auto mb-2 leading-relaxed">
      An open-source &amp; self-hostable alternative to Vercel, Heroku, Netlify, and Railway for easily deploying
      apps, databases, and 80+ one-click services to your own server.
    </h2>
    <p class="text-sm text-[var(--color-muted-foreground)] mb-8">
      Open source &amp; free forever, backed by <a href="/philosophy" class="underline text-[var(--color-foreground)] hover:text-[var(--color-primary)] transition-colors">our philosophy</a>.
    </p>

    <!-- Two big hero buttons — Coolify style -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center pb-4">
      <div>
        <a href="https://app.vessl.dev" class="flex items-center justify-center gap-2 px-8 py-4 rounded-lg font-semibold text-sm bg-[var(--color-surface)] hover:bg-[#1e1e28] border border-[var(--color-border)] text-white transition-colors">
          <svg class="size-5 text-[var(--color-primary)]" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>
          Cloud
        </a>
        <p class="text-[var(--color-muted-foreground)] text-xs mt-2 text-center">
          <span class="text-[var(--color-primary)] font-bold font-mono">1,200+</span> servers in the cloud.
        </p>
      </div>
      <div>
        <a href="https://docs.vessl.dev/self-host" target="_blank" class="flex items-center justify-center gap-2 px-8 py-4 rounded-lg font-semibold text-sm bg-[var(--color-surface)] hover:bg-[#1e1e28] border border-[var(--color-border)] text-white transition-colors">
          <svg class="size-5 text-[var(--color-primary)]" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
          Self-hosted
        </a>
        <p class="text-[var(--color-muted-foreground)] text-xs mt-2 text-center">
          <span class="text-[var(--color-primary)] font-bold font-mono">&lt;30MB</span> single binary.
        </p>
      </div>
    </div>
  </section>

  <!-- How it works — Aeroplane.run inspired -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
      <!-- Steps -->
      <div class="space-y-0">
        {steps.map((step, i) => (
          <div class={`p-6 border border-[var(--color-border)] bg-[var(--color-surface)] ${i === 0 ? 'rounded-t-xl' : ''} ${i === steps.length - 1 ? 'rounded-b-xl' : 'border-b-0'}`}>
            <div class="text-[var(--color-primary)] font-mono text-xs font-bold mb-2">{step.n}</div>
            <h3 class="font-bold text-[var(--color-foreground)] mb-1">{step.title}</h3>
            <p class="text-sm text-[var(--color-muted-foreground)] leading-relaxed" set:html={step.desc}/>
          </div>
        ))}
      </div>

      <!-- Terminal mock — Aeroplane.run right panel style -->
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] overflow-hidden">
        <div class="flex items-center justify-between px-4 py-2.5 border-b border-[var(--color-border)]">
          <span class="text-xs text-[var(--color-muted-foreground)] font-mono">Vessl agent</span>
          <span class="text-xs px-2 py-0.5 rounded bg-green-500/20 text-green-400 font-semibold">CONNECTED</span>
        </div>
        <div class="p-5 text-xs font-mono space-y-2">
          {[
            { label: 'SERVER', value: 'hetzner-fsn1-cx22' },
            { label: 'REGION', value: 'fsn1' },
            { label: 'AGENT', value: 'v0.4.0' },
            { label: 'DEPLOY', value: 'queued', highlight: true },
          ].map(row => (
            <div class="flex items-center border-b border-[var(--color-border)] pb-2 last:border-0 last:pb-0">
              <span class="text-[var(--color-muted-foreground)] w-24 shrink-0">{row.label}</span>
              <span class={row.highlight ? 'text-[var(--color-primary)] font-bold' : 'text-[var(--color-foreground)]'}>{row.value}</span>
            </div>
          ))}
        </div>
        <div class="border-t border-[var(--color-border)] p-4 text-xs font-mono text-[var(--color-muted-foreground)] space-y-1">
          <div class="font-semibold text-[var(--color-foreground)] text-[10px] tracking-widest uppercase mb-2">Included on deploy</div>
          {['Git repo, branch & root dir', 'Build command & env vars', 'Custom domain routing', 'Automatic SSL cert'].map(item => (
            <div class="flex items-center gap-2">
              <span class="size-1.5 rounded-full bg-[var(--color-primary)] shrink-0"></span>
              {item}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Features — plain grid no cards, Coolify style -->
  <section id="features" class="max-w-5xl mx-auto px-4 py-16 scroll-mt-20">
    <h2 class="text-4xl font-bold text-[var(--color-foreground)] text-center mb-16">Features</h2>
    <dl class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-12 text-left">
      {features.map(f => (
        <div class="flex flex-col">
          <dt class="flex items-center gap-3 text-lg font-semibold text-[var(--color-foreground)] mb-3">
            <svg class="size-6 text-[var(--color-primary)] shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" set:html={f.icon}/>
            {f.title}
          </dt>
          <dd class="text-sm text-[var(--color-muted-foreground)] leading-relaxed">{f.desc}</dd>
        </div>
      ))}
    </dl>
  </section>

  <!-- Jump to features floating button -->
  <a href="#features" id="jump-btn" class="fixed bottom-5 right-5 bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] text-white text-xs font-semibold px-4 py-2 rounded-full shadow-lg transition-all duration-300 z-40">
    Jump to Features
  </a>

</Layout>
