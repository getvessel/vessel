---
import Layout from '../layouts/Layout.astro';

const tableRows = [
  { feature: 'Application Deployments', sh: true, cloud: true },
  { feature: 'Database Deployments', sh: true, cloud: true },
  { feature: 'One-click Services', sh: true, cloud: true },
  { feature: 'API Access', sh: true, cloud: true },
  { feature: 'MCP Server (AI tools)', sh: true, cloud: true },
  { feature: 'Pull Request Previews', sh: true, cloud: true },
  { feature: 'Real-time Terminal', sh: true, cloud: true },
  { feature: 'Automatic SSL', sh: true, cloud: true },
  { feature: 'Codebase', sh: 'Open source', cloud: 'Open source' },
  { feature: 'Vessl Hosting', sh: 'Self-managed', cloud: 'Managed' },
  { feature: 'Dashboard Domain', sh: 'Custom domain', cloud: 'app.vessl.dev' },
  { feature: 'Setup', sh: 'Manual', cloud: 'Managed' },
  { feature: 'Email Alerts', sh: 'Bring your own SMTP', cloud: 'Managed' },
  { feature: 'Fleet Management', sh: '—', cloud: true },
  { feature: 'Usage Metering', sh: '—', cloud: true },
  { feature: 'Team Seats', sh: 'Unlimited', cloud: 'Unlimited' },
  { feature: 'Connected Servers', sh: 'Unlimited', cloud: 'Unlimited' },
  { feature: 'Future Features', sh: 'Unlimited & free', cloud: 'Included in price' },
];

const faqs = [
  { q: 'Do I get any Cloud-only features?', a: 'Fleet management, usage metering & billing alerts, and managed email notifications are Cloud-only. Every other feature ships in both editions simultaneously.' },
  { q: 'Does Vessl Cloud back up my application data?', a: 'Your apps and data live on your servers — Vessl never touches them. Vessl Cloud only stores control-plane metadata: deployment history, team info, and usage metrics.' },
  { q: 'Do I need to bring my own servers?', a: 'Yes. You connect your own servers (VPS, bare-metal, Raspberry Pi, EC2 — anything with SSH). Vessl runs the agent on your server and routes management traffic back through the cloud.' },
  { q: 'What happens if I cancel my Cloud subscription?', a: 'Your servers and deployments keep running uninterrupted — they are on your infrastructure. You simply lose access to the Cloud dashboard and fleet features. You can always self-host.' },
  { q: 'Is there a trial for Vessl Cloud?', a: 'Yes. A 14-day free trial is available, no credit card required.' },
  { q: 'Am I locked in?', a: 'Never. The self-hosted edition is MIT-licensed and free forever. Switching from Cloud to self-hosted is just a daemon config change.' },
];
---

<Layout title="Pricing — Vessl" description="Simple, transparent pricing. Self-hosted is free forever. Vessl Cloud starts at $5/month.">
  <div class="text-center pt-12 md:pt-24 pb-10 px-4">
    <h1 class="text-3xl font-bold tracking-tight text-[var(--color-foreground)] md:text-6xl">
      Pricing<span class="text-[var(--color-primary)]">.</span>
    </h1>
    <h2 class="text-base pt-2 text-[var(--color-muted-foreground)]">
      Pricing that adjusts according to your needs.
    </h2>
  </div>

  <div class="max-w-5xl mx-auto py-4 px-4">
    <!-- Two-col plans — Coolify style -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Self-hosted -->
      <div class="bg-[var(--color-surface)] p-6 rounded-xl flex flex-col justify-between border border-[var(--color-border)]">
        <div>
          <h2 class="text-2xl font-semibold text-[var(--color-foreground)] mb-3">Self-hosted</h2>
          <p class="text-3xl font-semibold text-[var(--color-foreground)] mb-6">
            Free Forever <span class="text-sm font-normal text-[var(--color-muted-foreground)]"></span>
          </p>
          <p class="text-sm text-[var(--color-muted-foreground)] leading-6 mb-6">
            Deploy Vessl on your own infrastructure without any restrictions on features.
          </p>
          <ul class="space-y-3 text-sm text-[var(--color-foreground)]">
            {['Full access to all features', 'Requires your own server', 'No limitations or restrictions', 'Community support', 'Automated or self-managed updates', 'All upcoming features included'].map(f => (
              <li class="flex items-start gap-3">
                <svg class="size-5 text-[var(--color-primary)] shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                {f}
              </li>
            ))}
          </ul>
        </div>
        <div class="mt-8">
          <a href="https://docs.vessl.dev/self-host" class="flex justify-center items-center gap-2 py-3.5 rounded-lg bg-[#1e1e28] hover:bg-[#252535] border border-[var(--color-border)] text-white font-semibold text-sm transition-colors">
            <svg class="size-5 text-[var(--color-primary)]" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M22 2L11 13"/><path d="M22 2L15 22l-4-9-9-4 22-7z"/></svg>
            Start Self-hosting
          </a>
        </div>
      </div>

      <!-- Cloud -->
      <div class="bg-[var(--color-surface)] p-6 rounded-xl flex flex-col justify-between border border-[var(--color-border)]">
        <div>
          <div class="flex items-center justify-between mb-3 gap-3 flex-wrap">
            <h2 class="text-2xl font-semibold text-[var(--color-foreground)]">Cloud</h2>
            <div class="inline-flex gap-1 p-1 bg-[var(--color-background)] rounded text-xs">
              <span class="px-3 py-1 bg-[var(--color-primary)] text-white rounded font-semibold">Monthly</span>
              <span class="px-3 py-1 text-[var(--color-muted-foreground)] font-semibold">
                Annually <span class="text-[var(--color-primary)]">(save 20%)</span>
              </span>
            </div>
          </div>
          <p class="text-3xl font-semibold text-[var(--color-foreground)] mb-1">
            $5 <span class="text-sm font-normal text-[var(--color-muted-foreground)]">/month base (connect 2 servers)</span>
          </p>
          <p class="text-sm text-[var(--color-primary)] font-semibold mb-4">+ $3 /month per additional server</p>
          <p class="text-sm text-[var(--color-muted-foreground)] leading-6 mb-6">
            Connect your servers. Vessl runs on our managed infrastructure.
          </p>
          <ul class="space-y-3 text-sm text-[var(--color-foreground)]">
            {['Connect unlimited servers', 'Unlimited deployments per server', 'Fleet dashboard', 'Usage metering & billing alerts', 'Email notifications (managed)', 'Community + priority email support'].map(f => (
              <li class="flex items-start gap-3">
                <svg class="size-5 text-[var(--color-primary)] shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <p class="mt-5 flex items-start gap-2 text-sm text-[var(--color-primary)]">
            <svg class="size-4 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            You bring your own servers — your apps never leave your infra.
          </p>
        </div>
        <div class="mt-8">
          <a href="https://app.vessl.dev/register" class="flex justify-center items-center gap-2 py-3.5 rounded-lg bg-[#1e1e28] hover:bg-[#252535] border border-[var(--color-border)] text-white font-semibold text-sm transition-colors">
            <svg class="size-5 text-[var(--color-primary)]" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M22 2L11 13"/><path d="M22 2L15 22l-4-9-9-4 22-7z"/></svg>
            Get Started in the Cloud
          </a>
        </div>
      </div>
    </div>

    <!-- Comparison table -->
    <div class="mt-14 overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="bg-[var(--color-surface)] border border-[var(--color-border)]">
            <th class="px-6 py-3 font-semibold text-[var(--color-foreground)] w-1/2">Feature</th>
            <th class="px-6 py-3 font-semibold text-[var(--color-foreground)] min-w-[140px]">Self-hosted</th>
            <th class="px-6 py-3 font-semibold text-[var(--color-foreground)] min-w-[100px]">Cloud</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[var(--color-border)] border border-t-0 border-[var(--color-border)]">
          {tableRows.map(row => (
            <tr class="hover:bg-[var(--color-surface)]/50 transition-colors">
              <td class="px-6 py-4 text-[var(--color-foreground)]">{row.feature}</td>
              <td class="px-6 py-4">
                {row.sh === true
                  ? <svg class="size-5 text-[var(--color-primary)]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                  : <span class="text-[var(--color-muted-foreground)]">{row.sh}</span>
                }
              </td>
              <td class="px-6 py-4">
                {row.cloud === true
                  ? <svg class="size-5 text-[var(--color-primary)]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                  : <span class="text-[var(--color-muted-foreground)]">{row.cloud}</span>
                }
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- FAQ -->
    <div class="mt-16 max-w-3xl mx-auto">
      <h2 class="text-2xl font-semibold text-[var(--color-foreground)] mb-6">Frequently Asked Questions</h2>
      <div class="divide-y divide-[var(--color-border)] border-y border-[var(--color-border)]">
        {faqs.map(faq => (
          <details class="py-4 group cursor-pointer">
            <summary class="w-full text-left text-sm font-semibold text-[var(--color-foreground)] flex justify-between items-center list-none">
              {faq.q}
              <svg class="size-5 text-[var(--color-muted-foreground)] group-open:rotate-180 transition-transform duration-200 shrink-0 ml-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <p class="mt-3 text-sm text-[var(--color-muted-foreground)] leading-relaxed">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </div>
</Layout>
