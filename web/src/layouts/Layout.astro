---
import '../styles/global.css';
import { Icon } from 'astro-icon/components';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Vessl — Self-hosting with superpowers',
  description = 'Deploy apps, databases, and services to your own server. Open-source, lightweight, and built for teams.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body class="bg-[var(--color-background)] text-[var(--color-foreground)] font-sans antialiased overflow-x-hidden max-w-[100vw]">

    <!-- Nav -->
    <header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-background)]/80 backdrop-blur-md">
      <nav class="max-w-7xl mx-auto px-4 flex items-center justify-between h-16">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 font-bold text-lg tracking-tight shrink-0">
          <span class="size-7 rounded-lg bg-[var(--color-primary)] flex items-center justify-center text-white text-xs font-black">V</span>
          Vessl
        </a>

        <!-- Desktop nav -->
        <div class="hidden lg:flex items-center gap-0.5 text-sm">

          <a href="/philosophy" class="flex items-center gap-1.5 px-3 py-2 rounded-md font-semibold text-[var(--color-foreground)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface)] transition-colors">
            <Icon name="lucide:lightbulb" class="size-4 text-[var(--color-primary)]" />
            Philosophy
          </a>

          <a href="/pricing" class="flex items-center gap-1.5 px-3 py-2 rounded-md font-semibold text-[var(--color-foreground)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface)] transition-colors">
            <Icon name="lucide:dollar-sign" class="size-4 text-[var(--color-primary)]" />
            Pricing
          </a>

          <a href="/changelog" class="flex items-center gap-1.5 px-3 py-2 rounded-md font-semibold text-[var(--color-foreground)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface)] transition-colors">
            <Icon name="lucide:clock" class="size-4 text-[var(--color-primary)]" />
            Changelog
          </a>

          <a href="https://docs.vessl.dev" target="_blank" class="flex items-center gap-1.5 px-3 py-2 rounded-md font-semibold text-[var(--color-foreground)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface)] transition-colors">
            <Icon name="lucide:book" class="size-4 text-[var(--color-primary)]" />
            Docs
          </a>

          <a href="https://github.com/techxteam/vessl" target="_blank" class="flex items-center gap-1.5 px-3 py-2 rounded-md font-semibold text-[var(--color-foreground)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface)] transition-colors">
            <Icon name="simple-icons:github" class="size-4 text-[var(--color-primary)]" />
            GitHub
          </a>

          <a href="https://discord.gg/vessl" target="_blank" class="flex items-center gap-1.5 px-3 py-2 rounded-md font-semibold text-[var(--color-foreground)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface)] transition-colors">
            <Icon name="simple-icons:discord" class="size-4 text-[var(--color-primary)]" />
            Community
          </a>
        </div>

        <!-- CTA -->
        <a href="https://app.vessl.dev" class="shrink-0 text-sm font-semibold px-4 py-2 rounded-lg bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] text-white transition-colors">
          Get Cloud
        </a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-24 border-t border-[var(--color-border)]">
      <div class="max-w-7xl mx-auto px-4 py-12 flex flex-col sm:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-2">
          <span class="size-6 rounded-md bg-[var(--color-primary)] flex items-center justify-center text-white text-xs font-black">V</span>
          <span class="text-sm text-[var(--color-muted-foreground)]">© 2026 Vessl. Open-source &amp; free forever.</span>
        </div>
        <div class="flex flex-wrap justify-center items-center gap-2 text-sm text-[var(--color-muted-foreground)]">
          <a href="/philosophy" class="px-3 py-2 rounded-md hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface)] transition-colors">Philosophy</a>
          <a href="/pricing" class="px-3 py-2 rounded-md hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface)] transition-colors">Pricing</a>
          <a href="/changelog" class="px-3 py-2 rounded-md hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface)] transition-colors">Changelog</a>
          <a href="https://docs.vessl.dev" target="_blank" class="px-3 py-2 rounded-md hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface)] transition-colors">Docs</a>

          <!-- Icon-only social links -->
          <div class="flex items-center gap-1 ml-2 pl-2 border-l border-[var(--color-border)]">
            <!-- GitHub -->
            <a href="https://github.com/techxteam/vessl" target="_blank" aria-label="GitHub"
              class="p-2 rounded-md text-[var(--color-muted-foreground)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface)] transition-colors">
              <Icon name="simple-icons:github" class="size-4" />
            </a>
            <!-- X (Twitter) -->
            <a href="https://x.com/vessldotdev" target="_blank" aria-label="X / Twitter"
              class="p-2 rounded-md text-[var(--color-muted-foreground)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface)] transition-colors">
              <Icon name="simple-icons:x" class="size-4" />
            </a>
            <!-- Discord -->
            <a href="https://discord.gg/vessl" target="_blank" aria-label="Discord"
              class="p-2 rounded-md text-[var(--color-muted-foreground)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-surface)] transition-colors">
              <Icon name="simple-icons:discord" class="size-4" />
            </a>
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>
