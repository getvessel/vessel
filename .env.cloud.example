# Vessel Cloud Backend — copy to .env.cloud and fill in your values

CLOUD_PORT=8081
VESSEL_CLOUD_URL=https://cloud.vessel.dev
VESSEL_CLOUD_JWT_SECRET=change-this-to-a-secure-random-secret-in-prod
CLOUD_DATABASE_URL=postgres://user:password@localhost:5432/vessel_cloud?sslmode=disable

# License key signing
LICENSE_PRIVATE_KEY=

# AWS SES (managed email)
AWS_REGION=us-east-1
SES_FROM_EMAIL=no-reply@vessel.dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_HOBBY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=

# Paddle billing (alternative)
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_HOBBY=
PADDLE_PRICE_PRO=
PADDLE_PRICE_TEAM=

# SAML SSO (optional)
SAML_IDP_METADATA_URL=

# Managed AI defaults — teams can override via BYOK
DEFAULT_OPENAI_KEY=
DEFAULT_ANTHROPIC_KEY=
