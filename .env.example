# Vessl Environment Configuration

# Core
PORT=8080
HOST=0.0.0.0
VESSL_DATA_DIR=./data
VESSL_HOST_IP=

# Security
VESSL_JWT_SECRET=change-this-to-a-secure-random-secret-in-prod
VESSL_TLS_EMAIL=admin@example.com

# Traefik Proxy Ports
# Uncomment and change if ports 80/443/8080 are already in use
# VESSL_TRAEFIK_HTTP_PORT=80
# VESSL_TRAEFIK_HTTPS_PORT=443
# VESSL_TRAEFIK_API_PORT=8080

# Docker Deployments
VESSL_RUNTIME_NETWORK=vessl-network
DEPLOY_HOST_PORT_START=4100
DEPLOY_HOST_PORT_END=4999
BUILDKIT_HOST=
DEPLOY_DRY_RUN=false

# Dashboard
VESSL_DASHBOARD_URL=http://localhost:3000
VESSL_STATIC_DIR=
VITE_APP_TITLE=Vessl

# Updates
VESSL_UPDATE_URL=https://api.github.com/repos/solomonolatunji/vessl/releases/latest
VESSL_DOWNLOAD_URL=https://github.com/solomonolatunji/vessl/releases

# Optional Integrations
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
VERCEL_REDIRECT_URI=http://localhost:8080/api/oauth/vercel/callback
LICENSE_PUBLIC_KEY=

# Cloud SaaS / Database
CLOUD_DATABASE_URL=host=localhost user=vessl password=vessl dbname=vesslcloud port=5432 sslmode=disable

# Billing (Optional, required if using Cloud Mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# Email (Optional, required for auth/invites in Cloud Mode)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
