# Vessel Self-Hosted — copy to .env and fill in your values

PORT=8080
HOST=0.0.0.0
VESSEL_DATA_DIR=./data
VESSEL_JWT_SECRET=change-this-to-a-secure-random-secret-in-prod
VESSEL_TLS_EMAIL=admin@example.com
VESSEL_HOST_IP=
VESSEL_STATIC_DIR=
VESSEL_DASHBOARD_URL=http://localhost:3000
VESSEL_RUNTIME_NETWORK=vessel-network
VESSEL_UPDATE_URL=https://api.github.com/repos/solomonolatunji/vessel/releases/latest
VESSEL_DOWNLOAD_URL=https://github.com/solomonolatunji/vessel/releases

DEPLOY_HOST_PORT_START=4100
DEPLOY_HOST_PORT_END=4999
BUILDKIT_HOST=

# Optional: Vercel OAuth integration
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
VERCEL_REDIRECT_URI=http://localhost:8080/api/oauth/vercel/callback

# Optional: Pro/Team license
LICENSE_PUBLIC_KEY=

# Dashboard
VITE_APP_TITLE=Vessel
